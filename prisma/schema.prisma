generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            String         @id @default(cuid())
  name          String?
  email         String?        @unique
  emailVerified DateTime?
  image         String?
  password      String?
  role          UserRole       @default(KARYAWAN)
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  department    String?
  lokasi        String?
  nip           String?
  enrollments   Enrollment[]
  testAttempts  TestAttempt[]
  userProgress  UserProgress[]
  notifications Notification[]
}

model Course {
  id          String       @id @default(cuid())
  userId      String
  title       String
  description String?
  imageUrl    String?
  isPublished Boolean      @default(false)
  categoryId       String?
  deadlineDuration Int?
  deadlineDate     DateTime?
  createdAt        DateTime     @default(now())
  updatedAt        DateTime     @updatedAt
  category         Category?    @relation(fields: [categoryId], references: [id])
  enrollments      Enrollment[]
  modules          Module[]
  tests            Test[]
  autoEnrollRules  AutoEnrollmentRule[]

  @@index([categoryId])
}

model Category {
  id      String   @id @default(cuid())
  name    String   @unique
  courses Course[]
}

model Module {
  id               String         @id @default(cuid())
  title            String
  description      String?
  position         Int            @default(0)
  isPublished      Boolean        @default(false)
  isFree           Boolean        @default(false)
  courseId         String
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt
  duration         Int            @default(0)
  type             ModuleType     @default(VIDEO)
  url              String?
  pdfUrl           String?
  sharepointUrl    String?
  videoUrl         String?
  fileSize         BigInt?
  originalFilename String?
  course           Course         @relation(fields: [courseId], references: [id], onDelete: Cascade)
  userProgress     UserProgress[]

  @@index([courseId])
}

model Test {
  id                  String        @id @default(cuid())
  title               String
  type                TestType
  courseId            String
  createdAt           DateTime      @default(now())
  updatedAt           DateTime      @updatedAt
  duration            Int           @default(30)
  passingScore        Int           @default(70)
  maxAttempts         Int           @default(0)   // 0 = unlimited
  randomizeQuestions  Boolean       @default(false)
  randomizeOptions    Boolean       @default(false)
  questions           Question[]
  course              Course        @relation(fields: [courseId], references: [id], onDelete: Cascade)
  attempts            TestAttempt[]

  @@index([courseId])
}

model Question {
  id        String       @id @default(cuid())
  text      String
  testId    String
  createdAt DateTime     @default(now())
  updatedAt DateTime     @default(now()) @updatedAt
  options   Option[]
  test      Test         @relation(fields: [testId], references: [id], onDelete: Cascade)
  answers   TestAnswer[]

  @@index([testId])
}

model Option {
  id          String       @id @default(cuid())
  text        String
  isCorrect   Boolean      @default(false)
  questionId  String
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @default(now()) @updatedAt
  question    Question     @relation(fields: [questionId], references: [id], onDelete: Cascade)
  testAnswers TestAnswer[]

  @@index([questionId])
}

model UserProgress {
  id          String   @id @default(cuid())
  userId      String
  moduleId    String
  isCompleted Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  module      Module   @relation(fields: [moduleId], references: [id], onDelete: Cascade)
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, moduleId])
  @@index([moduleId])
}

model Enrollment {
  id        String           @id @default(cuid())
  userId    String
  courseId  String
  createdAt DateTime         @default(now())
  updatedAt DateTime         @updatedAt
  status    EnrollmentStatus @default(IN_PROGRESS)
  course    Course           @relation(fields: [courseId], references: [id], onDelete: Cascade)
  user      User             @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, courseId])
  @@index([courseId])
}

model Notification {
  id        String           @id @default(cuid())
  userId    String
  type      NotificationType @default(SYSTEM)
  title     String
  body      String?
  href      String?
  readAt    DateTime?
  createdAt DateTime         @default(now())
  user      User             @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, readAt])
  @@index([userId, createdAt])
}

model TestAttempt {
  id          String       @id @default(cuid())
  userId      String
  testId      String
  score       Float
  passed      Boolean      @default(false)
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  completedAt DateTime?    @default(now())
  startedAt   DateTime?
  cheated     Boolean      @default(false)
  answers     TestAnswer[]
  test        Test         @relation(fields: [testId], references: [id], onDelete: Cascade)
  user        User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([testId])
}

model TestAnswer {
  id               String      @id @default(cuid())
  testAttemptId    String
  questionId       String
  selectedOptionId String?
  isCorrect        Boolean
  createdAt        DateTime    @default(now())
  question         Question    @relation(fields: [questionId], references: [id], onDelete: Cascade)
  selectedOption   Option?     @relation(fields: [selectedOptionId], references: [id], onDelete: Cascade)
  testAttempt      TestAttempt @relation(fields: [testAttemptId], references: [id], onDelete: Cascade)

  @@unique([testAttemptId, questionId])
  @@index([testAttemptId])
}

enum UserRole {
  ADMIN
  KARYAWAN
}

enum ModuleType {
  VIDEO
  PDF
}

enum TestType {
  PRE
  POST
}

enum EnrollmentStatus {
  IN_PROGRESS
  COMPLETED
  FAILED
}

enum NotificationType {
  SYSTEM
  ENROLLMENT
  COURSE_UPDATE
  REMINDER
}

model AutoEnrollmentRule {
  id             String   @id @default(cuid())
  courseId       String
  department     String
  isActive       Boolean  @default(true)
  bypassDeadline Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  course         Course   @relation(fields: [courseId], references: [id], onDelete: Cascade)

  @@index([courseId])
  @@index([department])
}

model DepartmentConfig {
  id             String   @id @default(cuid())
  departmentName String   @unique
  headEmail      String
  headName       String
  isActive       Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}
